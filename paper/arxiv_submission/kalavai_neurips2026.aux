\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Per-domain held-out evaluation loss for each specialist over training steps (Pythia-410M, freeze=4, seed=42). Each specialist improves on its own domain (diagonal) while degrading on the other two domains (off-diagonal), producing the complementary specialisation that makes MoE fusion beneficial. Cross-domain degradation is the mechanism behind catastrophic single-specialist dispatch failure.}}{18}{figure.caption.62}\protected@file@percent }
\newlabel{fig:trainingcurves}{{8}{18}{Per-domain held-out evaluation loss for each specialist over training steps (Pythia-410M, freeze=4, seed=42). Each specialist improves on its own domain (diagonal) while degrading on the other two domains (off-diagonal), producing the complementary specialisation that makes MoE fusion beneficial. Cross-domain degradation is the mechanism behind catastrophic single-specialist dispatch failure}{figure.caption.62}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Cross-domain evaluation matrix at Pythia-410M step 2,000 (freeze=4, seed=42). Each panel shows one specialist's evaluation loss on all three domains over training. Dashed horizontal lines mark the base model's loss on each domain. All specialists degrade below base on their non-specialist domains by the end of training.}}{18}{figure.caption.63}\protected@file@percent }
\newlabel{fig:crossdomain}{{9}{18}{Cross-domain evaluation matrix at Pythia-410M step 2,000 (freeze=4, seed=42). Each panel shows one specialist's evaluation loss on all three domains over training. Dashed horizontal lines mark the base model's loss on each domain. All specialists degrade below base on their non-specialist domains by the end of training}{figure.caption.63}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Fusion benefit (MoE improvement over best individual specialist, \%) as a function of specialist training steps at Pythia-410M. Benefit grows monotonically up to approximately 5,000 steps, then plateaus (freeze=4) or degrades (freeze=0) at longer horizons. The crossover between freeze=0 and freeze=4 regimes is shown in Section~\ref {sec:crossover}.}}{19}{figure.caption.64}\protected@file@percent }
\newlabel{fig:fusiontrajectory}{{10}{19}{Fusion benefit (MoE improvement over best individual specialist, \%) as a function of specialist training steps at Pythia-410M. Benefit grows monotonically up to approximately 5,000 steps, then plateaus (freeze=4) or degrades (freeze=0) at longer horizons. The crossover between freeze=0 and freeze=4 regimes is shown in Section~\ref {sec:crossover}}{figure.caption.64}{}}
