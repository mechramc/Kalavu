\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Main results across three model scales. \textbf  {Per-domain equal-weight evaluation}: each domain evaluated separately at consistent batch size (bs=4), equal-weight average $= (\mathcal  {L}_\text  {code} + \mathcal  {L}_\text  {sci} + \mathcal  {L}_\text  {fiction})/3$. Initial experiments used a mixed concatenated eval with asymmetric batch sizes; code review identified these inconsistencies and the protocol was corrected before submission (Appendix~\ref {app:evalcorrection}). Seed 42 shown; 410M multi-seed mean +7.70\% $\pm $0.02\% (seeds 42/137/2026). 6.9B seed 42. Base model loss values here differ from appendix tables using the original evaluation protocol.}}{6}{table.caption.25}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:main}{{1}{6}{Main results across three model scales. \textbf {Per-domain equal-weight evaluation}: each domain evaluated separately at consistent batch size (bs=4), equal-weight average $= (\mathcal {L}_\text {code} + \mathcal {L}_\text {sci} + \mathcal {L}_\text {fiction})/3$. Initial experiments used a mixed concatenated eval with asymmetric batch sizes; code review identified these inconsistencies and the protocol was corrected before submission (Appendix~\ref {app:evalcorrection}). Seed 42 shown; 410M multi-seed mean +7.70\% $\pm $0.02\% (seeds 42/137/2026). 6.9B seed 42. Base model loss values here differ from appendix tables using the original evaluation protocol}{table.caption.25}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Specialist divergence (per-domain improvement over base, \%) and fusion gain (MoE vs.\ best individual specialist, equal-weight), seed 42. Corrected evaluation: per-domain separate eval at consistent batch size (bs=4 for Pythia, bs=4 for Qwen). $\dagger $~Qwen-1.5B uses code + fiction only (2 specialists). Fusion gain conversion rate = gain/divergence. All Pythia routing $>$99.9\% per-domain deterministic.}}{6}{table.caption.26}\protected@file@percent }
\newlabel{tab:divergence}{{2}{6}{Specialist divergence (per-domain improvement over base, \%) and fusion gain (MoE vs.\ best individual specialist, equal-weight), seed 42. Corrected evaluation: per-domain separate eval at consistent batch size (bs=4 for Pythia, bs=4 for Qwen). $\dagger $~Qwen-1.5B uses code + fiction only (2 specialists). Fusion gain conversion rate = gain/divergence. All Pythia routing $>$99.9\% per-domain deterministic}{table.caption.26}{}}
\@writefile{toc}{\contentsline {paragraph}{Note on evaluation method.}{6}{section*.27}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {\textsc  {Kalavai}\xspace  core results (corrected evaluation).} \textbf  {(A)} Fusion improvement over the best individual specialist across model scales: +7.72\% at 410M, +7.49\% at 1B, +6.53\% at 6.9B (corrected per-domain equal-weight eval). Gains are proportional to specialist divergence; conversion rate 0.49$\times $ at 410M/1B, 0.79$\times $ at 6.9B. \textbf  {(B)} Training duration crossover: freeze=0 peaks at 2k steps then degrades; freeze=4 peaks at 5k steps and degrades more gradually; crossover at $\approx $5k steps. \textbf  {(C)} Routing failure modes: learned MoE routing achieves +14.1\% (old eval); single-specialist classifier dispatch degrades by $-$21.1\%. \textbf  {(D)} \textsc  {Kalavai}\xspace  vs.\ equal-compute alternatives at 410M (corrected eval): MoE and monolithic achieve near-parity on equal-weight loss; cooperative advantage is primarily vs.\ best individual specialist (+7.72\%). All results seed 42 or means over 3 seeds where noted.}}{7}{figure.caption.28}\protected@file@percent }
\newlabel{fig:hero}{{1}{7}{\textbf {\kalavai core results (corrected evaluation).} \textbf {(A)} Fusion improvement over the best individual specialist across model scales: +7.72\% at 410M, +7.49\% at 1B, +6.53\% at 6.9B (corrected per-domain equal-weight eval). Gains are proportional to specialist divergence; conversion rate 0.49$\times $ at 410M/1B, 0.79$\times $ at 6.9B. \textbf {(B)} Training duration crossover: freeze=0 peaks at 2k steps then degrades; freeze=4 peaks at 5k steps and degrades more gradually; crossover at $\approx $5k steps. \textbf {(C)} Routing failure modes: learned MoE routing achieves +14.1\% (old eval); single-specialist classifier dispatch degrades by $-$21.1\%. \textbf {(D)} \kalavai vs.\ equal-compute alternatives at 410M (corrected eval): MoE and monolithic achieve near-parity on equal-weight loss; cooperative advantage is primarily vs.\ best individual specialist (+7.72\%). All results seed 42 or means over 3 seeds where noted}{figure.caption.28}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Comparison to Equal-Compute Monolithic Training}{7}{subsection.4.3}\protected@file@percent }
